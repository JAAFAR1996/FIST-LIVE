# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Environment
NODE_ENV=development

# Session Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=change-this-to-a-long-random-secret-in-production

# Optional: Redis for session store in production
# REDIS_URL=redis://...

# Optional: Port (default: 5000)
# PORT=5000

# Optional: Client URL for CORS
# CLIENT_URL=https://your-domain.com
